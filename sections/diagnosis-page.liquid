<script>
  // Liquidのブロック設定をJSで使えるようにオブジェクト化
  window.diagnosisData = {};
  {% for block in section.blocks %}
    {% if block.type == 'diagnosis_result' %}
      {% assign clean_key = block.settings.result_key | strip | upcase %}
      window.diagnosisData["{{ clean_key }}"] = [
        {% if block.settings.product != blank %}
          {
            "productUrl": {{ block.settings.product.url | json }},
            "imageSrc": {{ block.settings.image | default: block.settings.product.featured_image | image_url: width: 600 | json }},
            "title": {{ block.settings.title_1 | default: block.settings.product.title | json }},
            "price": {{ block.settings.product.price | money_with_currency | json }}
          },
        {% endif %}
        {% if block.settings.product_2 != blank %}
          {
            "productUrl": {{ block.settings.product_2.url | json }},
            "imageSrc": {{ block.settings.image_2 | default: block.settings.product_2.featured_image | image_url: width: 600 | json }},
            "title": {{ block.settings.title_2 | default: block.settings.product_2.title | json }},
            "price": {{ block.settings.product_2.price | money_with_currency | json }}
          },
        {% endif %}
        {% if block.settings.product_3 != blank %}
          {
            "productUrl": {{ block.settings.product_3.url | json }},
            "imageSrc": {{ block.settings.image_3 | default: block.settings.product_3.featured_image | image_url: width: 600 | json }},
            "title": {{ block.settings.title_3 | default: block.settings.product_3.title | json }},
            "price": {{ block.settings.product_3.price | money_with_currency | json }}
          },
        {% endif %}
      ];
    {% endif %}
  {% endfor %}
  console.log('Diagnosis Data Loaded:', window.diagnosisData);
</script>
<script src="{{ 'diagnosis.js' | asset_url }}" defer="defer"></script>
{% schema %}
{
  "name": "t:sections.main-page.name",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "header",
      "content": "t:sections.all.padding.section_padding_heading"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_top",
      "default": 36
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "t:sections.all.padding.padding_bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "option_block",
      "name": "選択肢付きブロック",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "タイトル"
        },
          {
        "type": "text",
        "id": "option_1",
        "label": "選択肢1",
        
      },
      {
        "type": "text",
        "id": "option_2",
        "label": "選択肢2",
        
      },
      {
        "type": "text",
        "id": "option_3",
        "label": "選択肢3",
      }
      ]
    },
    {
      "type": "diagnosis_result",
      "name": "診断結果設定",
      "settings": [
        {
          "type": "text",
          "id": "result_key",
          "label": "結果キー (例: S-S, H-M)",
          "info": "JSのロジックで判定されるキーと一致させてください"
        },
        {
          "type": "header",
          "content": "おすすめ商品 1"
        },
        {
          "type": "product",
          "id": "product",
          "label": "商品"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "画像 (商品画像より優先)"
        },
        {
          "type": "text",
          "id": "title_1",
          "label": "表示タイトル (空欄なら商品名)"
        },
        {
          "type": "header",
          "content": "おすすめ商品 2"
        },
        {
          "type": "product",
          "id": "product_2",
          "label": "商品"
        },
        {
          "type": "image_picker",
          "id": "image_2",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "title_2",
          "label": "表示タイトル"
        },
        {
          "type": "header",
          "content": "おすすめ商品 3"
        },
        {
          "type": "product",
          "id": "product_3",
          "label": "商品"
        },
        {
          "type": "image_picker",
          "id": "image_3",
          "label": "画像"
        },
        {
          "type": "text",
          "id": "title_3",
          "label": "表示タイトル"
        }
      ]
    }
  ],
  "max_blocks": 20,
    "presets": [
    {
      "name": "選択肢ブロック付きセクション",
      "blocks": [
        {
          "type": "option_block"
        }
      ]
    }
  ]
}
{% endschema %}
