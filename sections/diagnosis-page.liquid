{{ 'section-main-page.css' | asset_url | stylesheet_tag }}
<!-- //これは診断ページ -->
{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="diagnosis page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {{ page.title | escape }}
  </h1>
  <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {{ page.content }}
  </div>
</div>
<div class="diagnosis_steps page-width page-width--narrow diagnosis_steps diagnosis_steps_box">
<div class="diagnosis_step__wrapper diagnosis_step_box__wrapper">
<div class="diagnosis_step diagnosis_step_box">
      {% assign step_count = 0 %}
      {% for block in section.blocks %}
        {% if block.type == 'option_block' %}
          {% assign step_count = step_count | plus: 1 %}
          <div class="diagnosis_step__inner diagnosis_step_box__inner js-diagnosis_step--{{ step_count }}">
            {% if step_count == 2 %}
              {% comment %} <div class="step_selected_info" id="step-selected-info-2"></div> {% endcomment %}
            {% elsif step_count == 3 %}
              {% comment %} <div class="step_selected_info" id="step-selected-info-3"></div> {% endcomment %}
            {% endif %}
            <div class="diagnosis_step__selected" id="{% if step_count == 1 %}selected-text-1{% elsif step_count == 2 %}selected-text-2{% else %}selected-text-3{% endif %}"></div>
            <div class="diagnosis_step__ttl_box js-diagnosis_step-ttl--{{ step_count }}" data-step="{{ step_count }}">
              <div class="diagnosis_step__sub-title">STEP{{ step_count }}</div>
              <div class="diagnosis_step__title">{{ block.settings.title }}</div>
            </div>
            <div class="diagnosis_step__contents js-diagnosis_step-cont--{{ step_count }}">
              <ul class="diagnosis_step__contents--lists">
                {% if block.settings.option_1 != blank %}
                  <li class="diagnosis_step__contents--list"><span>{{ block.settings.option_1 }}</span></li>
                {% endif %}
                {% if block.settings.option_2 != blank %}
                  <li class="diagnosis_step__contents--list"><span>{{ block.settings.option_2 }}</span></li>
                {% endif %}
                {% if block.settings.option_3 != blank %}
                  <li class="diagnosis_step__contents--list"><span>{{ block.settings.option_3 }}</span></li>
                {% endif %}
              </ul>
            </div>
          </div>
        {% endif %}
      {% endfor %}

</div>
