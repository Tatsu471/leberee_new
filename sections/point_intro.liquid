{{ 'section-main-page.css' | asset_url | stylesheet_tag }}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

<div class="page-width page-width--narrow section-{{ section.id }}-padding">
  <h1 class="main-page-title page-title h0{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}">
    {{ page.title | escape }}
  </h1>
  <div class="rte{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
    {{ page.content }}
  </div>
</div>
<div class="point-box_base">
 <div class="page-width point-box">
     <div class="custom-blocks" style="padding-top: {{ section.settings.padding_top }}px; padding-bottom: {{ section.settings.padding_bottom }}px;">
{% for block in section.blocks %}
  {% assign heading_align = block.settings.heading_alignment | default: 'left' %}
  {% assign subheading_align = block.settings.subheading_alignment | default: 'left' %}
  {% assign image_align = block.settings.image_alignment | default: 'center' %}
  {% assign desc_color = block.settings.description_color | default: '#333' %}

<div class="custom-block custom-block--{{ block.id }}{% if block.settings.icon %} has-icon{% endif %}">
    {% comment %} {# 見出し（h2） #} {% endcomment %}
    {% if block.settings.heading %}
      <div class="block-heading-wrapper text-{{ heading_align }}"
           style="margin-top: {{ block.settings.heading_margin_top }}px; margin-bottom: {{ block.settings.heading_margin_bottom }}px;">
        {% if block.settings.icon %}
          <img src="{{ block.settings.icon | image_url }}" alt="icon" class="block-icon" />
        {% endif %}
        <h2 class="block-heading"
            style="font-size: {{ block.settings.heading_font_size }}px;">{{ block.settings.heading }}</h2>
      </div>
    {% endif %}
    {% comment %} {# 小見出し（h3） #} {% endcomment %}
    {% if block.settings.subheading %}
      {% if block.settings.enable_arrow %}
      <div class="block-subheading-box-check">
      <h3 class="block-subheading text-{{ subheading_align }}"
          style="font-size: {{ block.settings.subheading_font_size }}px;
                 margin-top: {{ block.settings.subheading_margin_top }}px;
                 margin-bottom: {{ block.settings.subheading_margin_bottom }}px;">{{ block.settings.subheading }}</h3>
      </div>
      {% else %}
      <h3 class="block-subheading text-{{ subheading_align }}"
          style="font-size: {{ block.settings.subheading_font_size }}px;
                 margin-top: {{ block.settings.subheading_margin_top }}px;
                 margin-bottom: {{ block.settings.subheading_margin_bottom }}px;">{{ block.settings.subheading }}</h3>
          {% endif %}
    {% endif %}

    {% comment %} {# ↓↓↓ 説明と画像の順序制御部 ↓↓↓ #} {% endcomment %}
    {% if block.settings.reverse_text_image %}
      {% comment %} {# 画像 → 説明 の順番 #} {% endcomment %}
      {% if block.settings.image %}
        <div class="block-image-wrapper text-{{ image_align }}"><img src="{{ block.settings.image | image_url }}" alt="block image" class="block-image" /></div>
      {% endif %}
      {% if block.settings.description %}
        <p class="block-description text-{{ block.settings.alignment }}"
           style="color: {{ desc_color }};
                  font-size: {{ block.settings.description_font_size }}px;
                  margin-top: {{ block.settings.description_margin_top }}px;
                  margin-bottom: {{ block.settings.description_margin_bottom }}px;">{{ block.settings.description | escape | newline_to_br }}</p>
      {% endif %}
    {% else %}
      {% comment %} {# 説明 → 画像 の順番 #} {% endcomment %}
      {% if block.settings.description %}
        <p class="block-description text-{{ block.settings.alignment }}"
           style="color: {{ desc_color }};
                  font-size: {{ block.settings.description_font_size }}px;
                  margin-top: {{ block.settings.description_margin_top }}px;
                  margin-bottom: {{ block.settings.description_margin_bottom }}px;">
          {{ block.settings.description | escape | newline_to_br }}
        </p>
      {% endif %}
      {% if block.settings.image %}
        <div class="block-image-wrapper text-{{ image_align }}"><img src="{{ block.settings.image | image_url }}" alt="block image" class="block-image" /></div>
      {% endif %}
    {% endif %}
    {% comment %} {# ↑↑↑ 順序制御ここまで ↑↑↑ #} {% endcomment %}

    {% if block.settings.custom_html %}
      <div class="block-html">
        {{ block.settings.custom_html }}
      </div>
    {% endif %}
  </div>
{% endfor %}
   </div>
 </div>
</div>
{%- style -%} .point-box_base h2:empty, .point-box_base *:not(img,br):empty{
display:none;
}
