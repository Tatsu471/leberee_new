  .registration_link_box{
    padding-inline:40px;
    margin-bottom:20px;
  }
  .registration_link_box_link{
      text-decoration:none;
    trantision:0.3s;
     position: relative;
  z-index: 1;
  }
  .registration_link_box_link_text:after{
  content: '';
  position: absolute;
  left: 0;
  bottom: -4px;/*テキストからの距離*/
  width: 0%;/*初期状態では下線非表示*/
  height: 2px;/*下線の高さ*/
  background: #000;/*下線の色*/
  z-index: -1;
  transition: all 0.4s;/*アニメーション速度*/
}
.registration_link_box_link:hover .registration_link_box_link_text:after{
  width: 100%;/*hover時に表示*/
}



  .registration_link_box:hover{
      
    trantision:0.3s;
  }
  .section-template--25767452017006__point_intro-page-padding h1{
    display:none;
  }
  .block-heading-wrapper:has(h2:empty) img{
    display:none;
  }
  .custom-block:has(.block-subheading-box-check) .block-subheading-box-check .block-subheading {
  position: relative;
  display: inline-block; /* 矢印と見出しを横並びに */
  padding-right: 1.2em; /* 矢印との余白 */
}

.custom-block:has(.block-subheading-box-check) .block-subheading-box-check .block-subheading::after {
content: "";
    position: absolute;
    top: 15%;
    right: -10%;
    width: 26px;
    height: 26px;
    border-right: 1.4px solid #606060;
    border-bottom: 1.4px solid #606060;
    transform: translateY(-50%) rotate(45deg);
    transition: transform 0.5s ease;
}
   @media screen and (max-width: 768px) {
.custom-block:has(.block-subheading-box-check) .block-subheading-box-check .block-subheading::after{
      width: 17px;
    height: 17px;

}
.registration_link_box{
padding-inline:0;
    font-size: 12px;
}
 td, th{
    font-size: 12px !important;
    padding: .8em .6em !important;
}
table{
          margin-bottom: 10px;
}
.registration_link_box{
          margin-top: 8px;
        margin-bottom: 0;
}

  }
/* 開いた状態 */
.custom-block:has(.block-subheading-box-check) .block-subheading-box-check .block-subheading.active::after {
  transform:  rotate(225deg);
          top: 25%;
}

/* 折りたたみ部分 */
.custom-block:has(.block-subheading-box-check) .block-subheading-box-check + .block-description,.custom-block:has(.block-subheading-box-check) .block-subheading-box-check + .block-description + .block-image-wrapper,.custom-block:has(.block-subheading-box-check) .block-subheading-box-check + .block-description + .block-image-wrapper + .block-html {
  max-height: 0;
  overflow: hidden;
  opacity: 0;
  transform: translateY(-5px);
  transition: max-height 0.45s ease, opacity 0.45s ease, transform 0.45s ease;
}

/* 開いたとき */
.custom-block.open:has(.block-subheading-box-check) .block-subheading-box-check + .block-description,.custom-block.open:has(.block-subheading-box-check) .block-subheading-box-check + .block-description + .block-image-wrapper,.custom-block.open:has(.block-subheading-box-check) .block-subheading-box-check + .block-description + .block-image-wrapper .block-html {
  max-height: 1000px;
  opacity: 1;
  transform: translateY(0);
}
   @media screen and (max-width: 768px) {
.custom-block.open:has(.block-subheading-box-check) .block-subheading-box-check + .block-description,.custom-block.open:has(.block-subheading-box-check) .block-subheading-box-check + .block-description + .block-image-wrapper,.custom-block.open:has(.block-subheading-box-check) .block-subheading-box-check + .block-description + .block-image-wrapper .block-html {
margin-top:15px;
}
   }
{%- endstyle -%}
<script>
  document.addEventListener("DOMContentLoaded", function() {
  const headings = document.querySelectorAll(".block-subheading");

  headings.forEach(heading => {
    heading.addEventListener("click", function() {
      const parentBlock = heading.closest(".custom-block");
      const content = parentBlock.querySelector(".custom-block__content");

      // アコーディオン切り替え
      heading.classList.toggle("active");
      parentBlock.classList.toggle("open");

      // スムーズな開閉（display切替ではなくheightアニメーション）
      if (content.style.maxHeight) {
        content.style.maxHeight = null;
      } else {
        content.style.maxHeight = content.scrollHeight + "px";
      }
    });
  });
  document.querySelectorAll('.block-description').forEach(el => {
  if (el.textContent.trim() === '') {
    el.style.display = 'none';
  }
});
});
</script>
